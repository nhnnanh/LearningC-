<Window x:Class="WPFApp1.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFApp1"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800">
    <Grid Margin="0,0,90,-16">
        <Border Width="350" Background="#FFFFFF" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="Black"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Đăng nhập" FontSize="26" FontWeight="Black" Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="Tài khoản" FontSize="13" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,15" VerticalContentAlignment="Center" Background="#F9FAFB" BorderBrush="#D1D5DB" Foreground="#111827">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Mật khẩu" FontSize="13" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <PasswordBox x:Name="pwdPassword" Height="40" FontSize="14" Padding="12,0" Margin="0,0,0,25" VerticalContentAlignment="Center" Background="#F9FAFB" BorderBrush="#D1D5DB" Foreground="#111827">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <Button x:Name="btnLogin" Content="Đăng nhập" Height="45" FontSize="15" FontWeight="Bold" Background="#111827" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>
