<Window x:Class="WPFApp1.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFApp1"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Background="#F4F6F8" Grid.ColumnSpan="2">
            <Border Width="360"
            Padding="30"
            Background="White"
            CornerRadius="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Opacity="0.25"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Title -->
                    <TextBlock Text="Login"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#333333"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

                    <!-- Username -->
                    <TextBlock Text="Username"
                       FontSize="14"
                       Foreground="#555555"
                       Margin="0,0,0,6"/>

                    <TextBox x:Name="txtUsername"
                     Height="38"
                     FontSize="14"
                     Padding="10,0"
                     Margin="0,0,0,16"
                     VerticalContentAlignment="Center" TextChanged="txtUsername_TextChanged"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                       FontSize="14"
                       Foreground="#555555"
                       Margin="0,0,0,6"/>

                    <PasswordBox x:Name="pwdPassword"
                         Height="38"
                         FontSize="14"
                         Padding="10,0"
                         Margin="0,0,0,24"
                         VerticalContentAlignment="Center"/>

                    <!-- Button -->
                    <Button x:Name="btnLogin" Content="Đăng nhập"
                    Height="40"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Background="#FF7A00"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Button_Click"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
