<Window x:Class="WPFApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFApp1"
        mc:Ignorable="d"
        Title="Trang chính" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F4F6F8">

        <!-- Nội dung chính căn giữa màn hình -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="360">

            <Border Padding="40"
                    Background="White"
                    CornerRadius="16">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.25"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Icon chào mừng -->
                    <TextBlock Text="👋"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Dòng chào: Welcome, username -->
                    <!-- x:Name="lblWelcome" để code-behind có thể set nội dung -->
                    <TextBlock x:Name="lblWelcome"
                               Text="Welcome!"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#333333"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Bạn đã đăng nhập thành công."
                               FontSize="13"
                               Foreground="#888888"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32"/>

                    <!-- Nút Đăng xuất -->
                    <Button x:Name="btnLogout"
                            Content="🔓  Đăng xuất"
                            Height="42"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="#E53935"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnLogout_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8"
                                                    Padding="12,0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#C62828"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>
        </StackPanel>

    </Grid>
</Window>
